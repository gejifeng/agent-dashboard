# Optional: enables DeepSeek summaries. Never commit a real key.
DEEPSEEK_API_KEY=
# The settings screen also recognizes provider-specific environment keys:
# OPENAI_API_KEY=  OPENROUTER_API_KEY=  SILICONFLOW_API_KEY=

# Optional local fallback model and diagnostic log locations.
# Relative paths are resolved from the process working directory.
LOCAL_LLM_MODEL_PATH=models/Qwen3.5-2B-Q4_K_M.gguf
AGENT_DASHBOARD_LOG_DIR=runtime/logs
